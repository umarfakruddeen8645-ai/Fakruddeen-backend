  "license": "MIT",
  "engines": {
    "node": "18.x"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "bcrypt": "^5.1.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "deepspeech": "^0.9.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^2.5.1",
    "pg": "^8.11.1",
    "redis": "^5.12.1",
    "opencv4nodejs": "^5.6.0"
  }
