{
  "name": "fakruddeen-backend",
  "version": "1.0.0",
  "description": "Fakruddeen backend with Node.js, Express, PostgreSQL, Docker, and AI modules",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "node src/server/test.js",
    "migrate": "npx knex migrate:latest",
